<h1>CascadeDropdown</h1><hr /><br />
<head>
</head>
<div class="container">
    <div class="row">
        <div class="col-6 offset-3">
            <form method="post">
                <div class="form-group">
                    <label>Country:</label>
                    <select class="form-control mt-1" id="Country">
                    </select>
                </div>
                <div class="form-group mt-4">
                    <label>State:</label>
                    <select class="form-control mt-1" id="State">
                    </select>
                </div>
                <div class="form-group mt-4">
                    <label>City:</label>
                    <select class="form-control mt-1" id="City">
                    </select>
                </div>
                <div class="form-group mt-4">
                    <button type="submit" class="btn btn-md btn-primary float-end">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

