@model IEnumerable<ProductMVCProject.Models.Product>

@{
    ViewData["Title"] = "Product";
}

<h1>Product</h1>
<hr />

<p>
    <a class="btn btn-success" asp-controller="Product" asp-action="Create">Create New Product</a>
</p>

<div id="product-table"></div>

<div style="margin-top:10px; text-align:right;">
    <button id="btnDeleteSelected" class="btn btn-danger btn-sm" disabled>
        Delete Selected
    </button>
</div>

<link href="https://unpkg.com/tabulator-tables@6.3.0/dist/css/tabulator.min.css" rel="stylesheet" />
<link href="~/css/tabulator.css" rel="stylesheet" />
<script src="https://unpkg.com/tabulator-tables@6.3.0/dist/js/tabulator.min.js"></script>

<script>
    // Convert MVC Model -> JSON -> Tabulator
    const tableData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));

    const table = new Tabulator("#product-table", {
        // maxHeight: "100%",
        // minHeight: 300,
        layout: "fitColumns",
        responsiveLayout:true,
        resizableColumnGuide:true,
        data: tableData,
        selectable: true,
        pagination: true,
        paginationSize: 8,
        paginationSizeSelector:[3, 6, 8, 10],
        paginationCounter:"rows",
        movableRows:true,
        movableColumns: true,
        tooltips: true,
        // groupBy:"Description",
        rowHeader:{headerSort:false, width: 80, resizable: true, frozen:false, headerHozAlign:"center", hozAlign:"center", formatter:"rowSelection", 
                    titleFormatter:"rowSelection",
                    cellClick:function(e, cell){
                        cell.getRow().toggleSelect();
                    }
        },

        columns: [
            { formatter:"rownum", headerSort:true, hozAlign:"center", resizable:false, frozen:true, width:20},
            { title: "Id", field: "Id",width: 80,  hozAlign:"center", sorter: "number" },
            { title: "Name", field: "Name", sorter: "string" ,frozen: true },
            { title: "Price", field: "Price", sorter: "number" },
            { title: "Description", field: "Description", sorter: "string" },
            { title: "Stock", field: "Stock", sorter: "number",bottomCalc:"sum" },

            {
                title: "Edit",
                width: 90,
                formatter: () => "<button class='btn btn-primary btn-sm'>Edit</button>",
                cellClick: (e, cell) => {
                    const row = cell.getRow().getData();
                    window.location.href = `/Product/Edit/${row.Id}`;
                }
            },
            {
                title: "Delete",
                width: 100,
                formatter: () => "<button class='btn btn-danger btn-sm'>Delete</button>",
                cellClick: (e, cell) => {
                    const row = cell.getRow().getData();
                    window.location.href = `/Product/Delete/${row.Id}`;
                }
            }
        ]
    });

    const btn = document.getElementById("btnDeleteSelected");

    function refreshBtn(){
        const count = table.getSelectedRows().length;
        btn.disabled = count === 0;
        btn.innerText = count === 0 ? "Delete Selected" : `Delete Selected (${count})`;
    }

    table.on("rowSelectionChanged", refreshBtn);
    refreshBtn();

    btn.addEventListener("click", async () => {
        const rows = table.getSelectedRows();
        if(rows.length === 0) return;

        const ids = rows.map(r => r.getData().Id);

        if(!confirm(`Delete ${ids.length} product(s)?`)) return;

        // ✅ call your bulk delete API
        const res = await fetch("/Product/BulkDelete", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(ids)
        });

        if(res.ok){
            // ✅ remove from UI
            rows.forEach(r => r.delete());
            refreshBtn();
        }else{
            alert("Delete failed");
        }
    });
</script>
